{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chrome/**",
              "components/core/**",
              "components/display/**",
              "components/forms/**",
              "styles/**",
              "ui_kits/application/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Sora))/i]",
        "message": "Font not provided by the design system. Available: Inter, Sora."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:mint|lilac|almond|ink)$/]",
        "message": "<Badge> variant must be one of 'mint' | 'lilac' | 'almond' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|flat|block|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, flat, block, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|tertiary|outline|inverted)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'tertiary' | 'outline' | 'inverted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xl|l|m|s)$/]",
        "message": "<Button> size must be one of 'xl' | 'l' | 'm' | 's'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:headline|more|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: headline, more."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|flat|soft|tint|accent|contrast)$/]",
        "message": "<Card> variant must be one of 'default' | 'flat' | 'soft' | 'tint' | 'accent' | 'contrast'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|supportText|error|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, supportText, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='FixedActionBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:note|layout|key|ref|className|style|children)$/]",
        "message": "<FixedActionBar> doesn't accept that prop. Declared props: note, layout."
      },
      {
        "selector": "JSXOpeningElement[name.name='FixedActionBar'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:desktop|mobile)$/]",
        "message": "<FixedActionBar> layout must be one of 'desktop' | 'mobile'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Illustration'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|basePath|size|key|ref|className|style|children)$/]",
        "message": "<Illustration> doesn't accept that prop. Declared props: name, src, basePath, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|height|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:full|mark)$/]",
        "message": "<Logo> variant must be one of 'full' | 'mark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='NeedHelpCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|linkLabel|linkHref|icon|key|ref|className|style|children)$/]",
        "message": "<NeedHelpCard> doesn't accept that prop. Declared props: title, body, linkLabel, linkHref, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='OfferMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<OfferMeta> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='OtpInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:length|value|onChange|valid|error|className|key|ref|className|style|children)$/]",
        "message": "<OtpInput> doesn't accept that prop. Declared props: length, value, onChange, valid, error, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|label|valueLabel|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, label, valueLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|sub|status|key|ref|className|style|children)$/]",
        "message": "<TimelineStep> doesn't accept that prop. Declared props: title, sub, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineStep'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:done|active)$/]",
        "message": "<TimelineStep> status must be one of 'done' | 'active'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|supportText|error|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: label, supportText, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|min|max|step|value|defaultValue|onChange|prefix|suffix|showEnds|formatEnd|className|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: label, min, max, step, value, defaultValue, onChange, prefix, suffix, showEnds, formatEnd, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:popular)$/]",
        "message": "<Tag> variant must be one of 'popular'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|description|helper|count|valid|error|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, description, helper, count, valid, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|labelLarge|description|type|prefix|suffix|search|password|helper|count|maxLength|valid|error|value|defaultValue|onChange|inputProps|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, labelLarge, description, type, prefix, suffix, search, password, helper, count, maxLength, valid, error, value, defaultValue, onChange, inputProps."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|rating|reviews|variant|key|ref|className|style|children)$/]",
        "message": "<TrustBar> doesn't accept that prop. Declared props: items, rating, reviews, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustBar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<TrustBar> variant must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='YesNo'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|value|defaultValue|onChange|yesLabel|noLabel|className|key|ref|className|style|children)$/]",
        "message": "<YesNo> doesn't accept that prop. Declared props: name, value, defaultValue, onChange, yesLabel, noLabel, className."
      }
    ]
  },
